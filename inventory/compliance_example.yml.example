---
# Example Inventory for Compliance Checking
# 
# Copy this to inventory/compliance.yml and customize for your networks
#
# For compliance checking, we need networks as hosts (not orgs)
# Each network hostname should match network_name in group_vars

all:
  children:
    meraki_networks:
      hosts:
        # Network hostnames must match network_name in meraki_desired_ssids
        Corporate-Office:
          meraki_network_id: "N_1234567890abcdef"
          meraki_org_id: "YOUR_ORG_ID"  # Optional, can be set in group_vars
          
        Remote-Office:
          meraki_network_id: "N_abcdef1234567890"
          meraki_org_id: "YOUR_ORG_ID"
          
        # Add more networks as needed
        # Another-Office:
        #   meraki_network_id: "N_..."
        #   meraki_org_id: "YOUR_ORG_ID"
      
      vars:
        # Common variables for all Meraki networks
        ansible_connection: local
        ansible_python_interpreter: "{{ ansible_playbook_python }}"
        
        # Meraki API configuration (can also use environment variable)
        meraki_api_key: "{{ lookup('env', 'MERAKI_API_KEY') }}"
        meraki_org_name: "Your Organization"  # Optional
