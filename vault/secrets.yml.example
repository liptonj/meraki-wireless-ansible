---
# Ansible Vault Encrypted Secrets - Example Template
#
# INSTRUCTIONS:
# 1. Copy this file: cp vault/secrets.yml.example vault/secrets.yml
# 2. Fill in your actual secret values (replace all placeholders)
# 3. Encrypt with Ansible Vault:
#    ansible-vault encrypt vault/secrets.yml
# 4. Use the vault password file or prompt for password when running playbooks
#
# IMPORTANT SECURITY NOTES:
# - NEVER commit the encrypted secrets.yml to version control if it contains production secrets
# - Use different vault files for different environments (secrets_sandbox.yml, secrets_production.yml)
# - Store vault passwords securely (use password managers, not plain text files)
# - Rotate API keys and passwords regularly
#
# To edit encrypted file: ansible-vault edit vault/secrets.yml
# To view encrypted file: ansible-vault view vault/secrets.yml
# To decrypt temporarily: ansible-vault decrypt vault/secrets.yml

# ============================================================================
# Meraki API Credentials
# ============================================================================

# Meraki Dashboard API Key
# Get from: Meraki Dashboard > My Profile > API access
# Format: Usually starts with a long alphanumeric string
vault_meraki_api_key: "your_meraki_api_key_here"

# ============================================================================
# Sandbox Environment Secrets
# ============================================================================

# Meraki Organization ID
# Query via API: GET https://api.meraki.com/api/v1/organizations
vault_meraki_org_id: "your_org_id_here"

# Meraki Network IDs
# Query via API: GET https://api.meraki.com/api/v1/organizations/{orgId}/networks
vault_meraki_network_id_1: "your_network_id_1_here"
vault_meraki_network_id_2: "your_network_id_2_here"
# Add more network IDs as needed

# Sandbox Test SSID PSK (for testing purposes)
vault_sandbox_test_psk: "TestPassword123!"

# ============================================================================
# Production Environment Secrets (Example)
# ============================================================================

# Production Meraki Organization ID
# Find in: Meraki Dashboard > Organization > Settings
vault_meraki_org_id_prod: "your_production_org_id_here"

# Production API Key (use a separate key for production!)
vault_meraki_api_key_prod: "your_production_api_key_here"

# Production Network IDs
vault_meraki_network_id_prod_1: "your_production_network_id_1_here"
vault_meraki_network_id_prod_2: "your_production_network_id_2_here"
# Add all production network IDs

# ============================================================================
# RADIUS Server Credentials
# ============================================================================

# Primary RADIUS Server Configuration
vault_radius_server_1_host: "radius1.example.com"
vault_radius_server_1_secret: "your_radius_shared_secret_here"

# Secondary RADIUS Server (for redundancy)
vault_radius_server_2_host: "radius2.example.com"
vault_radius_server_2_secret: "your_radius_shared_secret_2_here"

# RADIUS Accounting Server
vault_radius_accounting_server_host: "radius-accounting.example.com"
vault_radius_accounting_server_secret: "your_radius_accounting_secret_here"

# ============================================================================
# SSID Passwords (PSK)
# ============================================================================

# Guest Network PSK
vault_guest_ssid_psk: "your_guest_network_password_here"

# Corporate BYOD PSK (if using PSK instead of 802.1X)
vault_corporate_byod_psk: "your_corporate_byod_password_here"

# IoT Network PSK (if applicable)
vault_iot_ssid_psk: "your_iot_network_password_here"

# ============================================================================
# Additional Secrets (Add as needed)
# ============================================================================

# Webhook URLs for monitoring/notifications
vault_webhook_url: "https://your-webhook-url.com/meraki-events"

# SMTP credentials for email notifications (if needed)
vault_smtp_server: "smtp.example.com"
vault_smtp_username: "your_smtp_username"
vault_smtp_password: "your_smtp_password"

# ============================================================================
# Usage Examples
# ============================================================================

# To use these secrets in playbooks:
#   meraki_api_key: "{{ vault_meraki_api_key }}"
#   radius_secret: "{{ vault_radius_server_1_secret }}"
#
# To run playbooks with vault:
#   ansible-playbook playbook.yml --ask-vault-pass
#   ansible-playbook playbook.yml --vault-password-file ~/.ansible_vault_pass
#
# To create vault password file (secure it!):
#   echo "your_vault_password" > ~/.ansible_vault_pass
#   chmod 600 ~/.ansible_vault_pass
