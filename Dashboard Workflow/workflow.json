                      "actions": [
                        {
                          "unique_name": "definition_activity_02U4BHKRT4N3N3ymvz68wWZ4fHI4HVCAo4d",
                          "name": "Build Payload",
                          "title": "Build Payload",
                          "type": "python3.script",
                          "base_type": "activity",
                          "properties": {
                            "action_timeout": 180,
                            "continue_on_failure": false,
                            "display_name": "Build Payload",
                            "script": "import sys\nimport json\n\nnet_name = sys.argv[1]\nssid_name = sys.argv[2]\nauth_mode = sys.argv[3]\nenc_mode = sys.argv[4]\nband = sys.argv[5]\nenabled = sys.argv[6].lower() == 'true'\nvisible = sys.argv[7].lower() == 'true'\ndry_run = sys.argv[8].lower() == 'true'\npsk = sys.argv[9]\n\npayload = {\n    \"event_type\": \"deploy-ssids\",\n    \"client_payload\": {\n        \"target_networks\": net_name,\n        \"ssid_name\": ssid_name,\n        \"auth_mode\": auth_mode,\n        \"encryption_mode\": enc_mode,\n        \"band_selection\": band,\n        \"ssid_enabled\": enabled,\n        \"ssid_visible\": visible,\n        \"dry_run\": dry_run\n    }\n}\n\nif auth_mode == 'psk' and psk:\n    payload[\"client_payload\"][\"psk_secret\"] = psk\n\nresult = json.dumps(payload)\n",
