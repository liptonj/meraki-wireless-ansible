---
# Ansible Lint Configuration
# See: https://ansible-lint.readthedocs.io/configuring/

skip_list:
  - yaml[line-length]
  - name[casing]
  - name[role-name]
  - command-instead-of-module
  - no-log-password
  - var-naming[no-role-prefix]
  - run-once[task]

enable_list:
  - yaml
  - name
  - syntax-check
  - risky-shell-pipe
  - risky-file-permissions

exclude_paths:
  - .github/
  - .devcontainer/
  - vault/
  - .ansible/
  - venv/
  - .git/
  - __pycache__/
  - "*.pyc"
  - .env

use_default_rules: true
