# Meraki API Configuration
# Copy to .env and fill in your values: cp .env.example .env
# Get your API key from: https://dashboard.meraki.com/ -> My Profile -> API access

MERAKI_DASHBOARD_API_KEY=your_meraki_dashboard_api_key_here
MERAKI_ORG_NAME=your_organization_name_here

# Single network:
# MERAKI_NETWORK_NAME=your_network_name_here

# Multiple networks (comma-separated):
MERAKI_NETWORK_NAMES=Site-A,Site-B,Site-C

ENVIRONMENT=production

# macOS: Prevents 'worker found in dead state' errors with Ansible
# See: https://developer.cisco.com/meraki/api-v1/ansible/#troubleshooting
OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# Uncomment if needed:
# MERAKI_BASE_URL=https://api.meraki.com/api/v1

# Alerting (optional)
# WEBEX_WEBHOOK_URL=https://webexapis.com/v1/webhooks/incoming/your-webhook-id
# COMPLIANCE_GITHUB_REPO=your-username/meraki-wireless-ansible

# Webex Bot (optional - for direct user alerts)
# Create a bot at https://developer.webex.com/my-apps/new/bot
# WEBEX_BOT_TOKEN=your_webex_bot_access_token
# WEBEX_ALERT_EMAIL=user_to_alert@example.com
# WEBEX_WEBHOOK_SECRET=your_hmac_shared_secret
